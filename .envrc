# direnv config for /Users/benjamincrane/ops-engine-x
#
# Activates automatically when you `cd` into this directory IF direnv is
# installed and hooked into your shell. If direnv is NOT installed, this
# file is inert — safe to leave in the repo.
#
# Purpose: strip the four DOPPLER_* env vars that your shell inherits from a
# home-directory default (sfdc-engine-x / hq-dev / etc.). Without stripping
# them, `doppler run` from this directory silently uses the wrong project.
# With them stripped, Doppler falls back to this directory's scoped config
# (project: ops-engine-x, config: prd).
#
# To enable direnv:
#   brew install direnv
#   echo 'eval "$(direnv hook zsh)"' >> ~/.zshrc  # or bash / fish equivalent
#   direnv allow .
#
# Without direnv, use ./scripts/doppler instead — same effect.

unset DOPPLER_TOKEN
unset DOPPLER_PROJECT
unset DOPPLER_CONFIG
unset DOPPLER_ENVIRONMENT
